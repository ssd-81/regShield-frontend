# Base URL of the RegShield Go API. Defaults to http://localhost:8080 if unset.
VITE_API_URL=http://localhost:8080

# --- Voice tab (Dograh integration) ---
# Dograh base URL. The voice hook rewrites http->ws for the signaling socket.
VITE_DOGRAH_WS_URL=http://localhost:8000
# voice-bridge endpoint that mints a per-call session (token + run id).
VITE_VOICE_BOOTSTRAP_URL=http://localhost:8787/voice/session
